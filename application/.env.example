# ============================================
# Go Backend Template - Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env with real credentials
# ============================================

# ------------------------------------------
# Server Configuration
# ------------------------------------------

# Server port (default: 8081)
PORT=8081

# Application environment (development, staging, production)
APP_ENV=development

# ------------------------------------------
# Logging Configuration
# ------------------------------------------

# Log level: DEBUG, INFO, WARN, ERROR (default: INFO)
# DEBUG   - Detailed diagnostic information (development)
# INFO    - General informational messages (default)
# WARN    - Warning conditions that require attention
# ERROR   - Error conditions and failures
#
# Examples:
# LOG_LEVEL=DEBUG  # Show all messages
# LOG_LEVEL=WARN   # Only warnings and errors
# LOG_LEVEL=ERROR  # Only errors
#
# Precedence: LOG_LEVEL env var > config file > default (INFO)
LOG_LEVEL=INFO

# ------------------------------------------
# Database Configuration
# ------------------------------------------

# PostgreSQL connection string
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/go_backend?sslmode=disable

# ------------------------------------------
# Kafka Configuration
# ------------------------------------------

# Kafka broker addresses (comma-separated)
KAFKA_BROKERS=localhost:9092

# Kafka topic name
KAFKA_TOPIC=events

# Kafka consumer group ID
KAFKA_GROUP_ID=ms-casino-go-v2

# Number of parallel Kafka workers
KAFKA_WORKERS=5

# ------------------------------------------
# Application Configuration
# ------------------------------------------

# Idempotency lock TTL in seconds (default: 30)
IDEMPOTENCY_LOCK_TTL=30

# ------------------------------------------
# Optional: Datadog APM (HML and PRD environments)
# ------------------------------------------
# The Go tracer sends spans to the Datadog Agent sidecar (localhost:8126).
# DD_API_KEY is configured in the Agent sidecar (K8s Secret) — not here.
# See: docs/architecture/project-decisions/ADR-002-datadog-go-sdk-integration.md

# Custom app toggle — set true in hml/prd, false locally (default: false)
# DD_ENABLED=false

# Unified Service Tagging (required by Datadog for metrics/traces/logs correlation)
# DD_SERVICE=ms-casino-go-v2
# DD_ENV=development
# DD_VERSION=1.0.0

# APM sampling rate (0.0–1.0) — read natively by dd-trace-go v2; 1.0 = 100% in all envs
# DD_TRACE_SAMPLE_RATE=1.0
