# -----------------------------------------------------------------------
# .env.example — copy to .env for local development (never commit .env)
# This file is NOT loaded at runtime; it documents required env vars only.
# -----------------------------------------------------------------------

# Required — Aurora PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/dbname?sslmode=disable

# Required — Kafka broker addresses, comma-separated
KAFKA_BROKERS=localhost:9092

# Required — Kafka topic to consume customer update events from
KAFKA_TOPIC=events

# Optional — HTTP port (default: 8081)
PORT=8081

# Optional — Kafka consumer group ID (default: casino-proxy-ai)
KAFKA_GROUP_ID=casino-proxy-ai

# Optional — Kafka worker goroutine pool size (default: 5)
KAFKA_WORKERS=5

# Optional — Idempotency lock TTL in seconds (default: 30)
# The lock prevents duplicate processing of the same message.
# If processing fails, the lock is released so the message can be retried.
IDEMPOTENCY_LOCK_TTL=30

# Optional — Application environment: development | staging | production (default: development)
APP_ENV=development
