#!/bin/sh
# commit-msg hook: Prevent LLM attribution in commit messages
# Only blocks "Co-Authored-By:" patterns - does NOT block general text like "Claude" in descriptions

COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2

# Skip validation for merge commits, squash, etc.
if [ "$COMMIT_SOURCE" != "" ]; then
    exit 0
fi

# Read commit message
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Block LLM attribution patterns to maintain human-maintained template integrity
# Only block patterns in footer/attribution context (after 2+ blank lines or as trailer)
if echo "$COMMIT_MSG" | grep -qi "^Co-Authored-By:"; then
    echo "❌ Commit rejected: LLM attribution not allowed in commits"
    echo ""
    echo "Your commit message contains 'Co-Authored-By:'"
    echo ""
    echo "This template is maintained by human developers."
    echo "Please remove Co-Authored-By attribution from commit messages."
    echo ""
    exit 1
fi

# Block AI generation footers (at end of message after blank line)
if echo "$COMMIT_MSG" | grep -E "^(Generated with (Claude|ChatGPT|AI)|Generated by AI)$" | tail -1 | grep -qi "generated"; then
    echo "❌ Commit rejected: AI attribution footers not allowed"
    echo ""
    echo "This template is maintained by human developers."
    echo "Please remove AI generation attribution from commit messages."
    echo ""
    exit 1
fi

exit 0
