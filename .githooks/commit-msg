#!/bin/bash
# Git hook: commit-msg
# Purpose: Block commits with LLM (Claude, ChatGPT, etc) attribution
#
# LLMs should NOT be credited as co-authors. They are tools used by humans.
# This hook prevents accidental commits that credit LLMs.

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# List of LLM patterns to block
LLM_PATTERNS=(
  "Co-Authored-By.*Claude"
  "Co-Authored-By.*ChatGPT"
  "Co-Authored-By.*GPT-"
  "Co-Authored-By.*Copilot"
  "Co-Authored-By.*Gemini"
  "Co-Authored-By.*LLaMA"
  "Co-Authored-By.*Grok"
  "Co-Authored-By.*Mixtral"
  "Co-Authored-By.*Llama"
  "Co-Authored-By.*AI"
  "authored by.*Claude"
  "authored by.*ChatGPT"
  "authored by.*AI"
)

# Check each pattern
for pattern in "${LLM_PATTERNS[@]}"; do
  if echo "$COMMIT_MSG" | grep -qiE "$pattern"; then
    echo ""
    echo "❌ COMMIT BLOCKED: LLM attribution detected"
    echo ""
    echo "   ❗ LLMs are TOOLS, not co-authors"
    echo "   ℹ️  Remove any 'Co-Authored-By' lines crediting AI tools"
    echo ""
    echo "   Found pattern: $pattern"
    echo ""
    echo "   Valid commit message:"
    echo "   - Only list HUMAN authors/co-authors"
    echo "   - Mention tools in commit body if relevant (not as co-authors)"
    echo ""
    echo "   📚 Reference: .claude/rules/git-commit-restrictions.md"
    echo ""
    exit 1
  fi
done

exit 0
