#!/bin/bash
# Git pre-push hook: Block direct push to protected branches
# Installed: 2026-05-12
# Purpose: Enforce PR-based workflow for main/master branches

protected_branches=("master" "main")
current_branch=$(git rev-parse --abbrev-ref HEAD)

# Check if current branch is protected
for branch in "${protected_branches[@]}"; do
  if [ "$current_branch" = "$branch" ]; then
    echo ""
    echo "❌ PUSH BLOQUEADO: Não é permitido push direto para '$branch'"
    echo ""
    echo "   ℹ️  Fluxo correto:"
    echo "      1. git push origin feature/seu-branch"
    echo "      2. gh pr create --title 'Sua PR' --body 'Descrição'"
    echo "      3. @devops faz merge após validação"
    echo ""
    echo "   📚 Referência: .claude/rules/git-push-restrictions.md"
    echo ""
    exit 1
  fi
done

exit 0
